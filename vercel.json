{
  "version": 2,
  "installCommand": "npm install --prefix frontend",
  "buildCommand": "rm -rf dist && npm run build --prefix frontend && cp -R frontend/dist dist",
  "outputDirectory": "dist",
  "functions": {
    "api/index.py": {
      "includeFiles": "data/**"
    }
  },
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon.svg"
    },
    {
      "source": "/api/v1/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/journey/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/user/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/locations",
      "destination": "/api/index.py"
    },
    {
      "source": "/traffic",
      "destination": "/api/index.py"
    },
    {
      "source": "/plan",
      "destination": "/api/index.py"
    },
    {
      "source": "/coupons",
      "destination": "/api/index.py"
    },
    {
      "source": "/coupons/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
